# ── Business identity ─────────────────────────────────────────────────────
# Unique ID for this business used as the backend tenant identifier
BUSINESS_ID=my-business

# ── Stripe (https://dashboard.stripe.com) ─────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# ── ReviewBoost API ────────────────────────────────────────────────────────
REVIEWBOOST_API_URL=http://localhost:3001
REVIEWBOOST_API_SECRET=change_me_to_a_long_random_string

# ── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Feedback Email (gatekeeping review page) ───────────────────────────────
# Fallback owner email if Clerk lookup fails
FEEDBACK_TO_EMAIL=owner@example.com

# SMTP settings for sending feedback emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com
