# ── Clerk (https://clerk.com) ──────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Stripe (https://dashboard.stripe.com) ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# ── ReviewBoost API ────────────────────────────────────────────────────────────
REVIEWBOOST_API_URL=http://localhost:3001
REVIEWBOOST_API_SECRET=change_me_to_a_long_random_string

# ── Supabase (https://supabase.com) ───────────────────────────────────────────
# Create a project at supabase.com, then run the SQL in supabase/migrations/ in
# the Supabase SQL editor (or via the Supabase CLI: supabase db push).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Settings → API → service_role key (keep secret)

# ── Dev overrides ─────────────────────────────────────────────────────────────
# Set to "true" to skip Stripe subscription checks during local development.
BYPASS_SUBSCRIPTION=false

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Root domain for subdomain tenant resolution.
# e.g. if set to "reviewautomater.com", then acme.reviewautomater.com resolves
# to the tenant with slug "acme".
# For local development use "localhost:3000" (subdomains don't work locally without
# a hosts file entry or a tool like localho.st).
NEXT_PUBLIC_ROOT_DOMAIN=reviewautomater.com

# ── Super admin ────────────────────────────────────────────────────────────────
# Grant /super-admin access to a Clerk user by setting their privateMetadata:
#   { "isSuperAdmin": true }
# Do this via Clerk dashboard → Users → select user → Metadata → Private.
# Or via Clerk Backend API: PATCH /v1/users/{user_id} { "private_metadata": { "isSuperAdmin": true } }
